# Generated by Ansible, local modifications will be overwritten

---
hostname_fqdn: {{ datadog_hostname_fqdn | to_json }}
api_key: {{ datadog_api_key }}
hostname: ''
bind_host: {{ datadog_bind_host }}
additional_endpoints: {}
tags: {{ datadog_tags | to_nice_yaml(indent=2) | trim }}
dogstatsd_non_local_traffic: false
histogram_aggregates:
- max
- median
- avg
- count
histogram_percentiles:
- '0.95'
use_dogstatsd: true
dogstatsd_port: 8125
log_level: INFO
logs_enabled: {{ datadog_logs_enabled | to_json }}
log_file: "/var/log/datadog/agent.log"
process_config:
  enabled: "{{ 'true' if datadog_process_enabled else 'false' }}"
  intervals: {}
  blacklist_patterns: []
  scrub_args: true
  custom_sensitive_words: []
  process_dd_url: https://process.datadoghq.com
apm_config:
  apm_non_local_traffic: false